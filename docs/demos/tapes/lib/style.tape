# Shared look for all roboto-mem demo tapes. Set-only — sourced before any action.
Set Shell zsh
Set FontSize 24
Set Width 1200
Set Height 700
Set Padding 24
Set Margin 0
Set WindowBar Colorful
Set BorderRadius 8
Set Theme "Catppuccin Mocha"
Set TypingSpeed 60ms
Set Framerate 24
Set CursorBlink false
