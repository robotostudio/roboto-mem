{
  "name": "roboto-mem",
  "version": "0.3.0",
  "description": "Team Memory sync for Claude Code — git-backed knowledge base injected into agent sessions",
  "license": "MIT",
  "packageManager": "pnpm@10.32.1",
  "repository": { "type": "git", "url": "git+https://github.com/robotostudio/roboto-mem.git" },
  "homepage": "https://github.com/robotostudio/roboto-mem#readme",
  "keywords": ["claude-code", "claude", "memory", "knowledge-base", "team", "standards", "plugin"],
  "type": "module",
  "bin": { "roboto-mem": "./dist/cli.mjs" },
  "files": ["dist", "README.md", "LICENSE"],
  "engines": { "node": ">=20" },
  "scripts": {
    "prepublishOnly": "pnpm build && pnpm test",
    "build": "tsdown",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src tests scripts",
    "lint:fix": "biome check --write src tests scripts",
    "check:version": "node scripts/check-version-sync.mjs",
    "bump": "node scripts/bump-version.mjs"
  },
  "dependencies": { "@clack/prompts": "^1.7.0", "citty": "^0.1.6", "tinyglobby": "^0.2.10", "yaml": "^2.6.0" },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@types/node": "^20.17.0",
    "@vitest/coverage-v8": "^4.0.0",
    "tsdown": "^0.12.0",
    "typescript": "^5.8.0",
    "vitest": "^4.0.0"
  }
}
